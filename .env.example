# Discord bot token (https://discord.com/developers/applications で発行)
DISCORD_BOT_TOKEN=

# Gemini API key (既存のものを流用可)
GEMINI_API_KEY=

# 動作対象サーバー ID (省略すると全サーバーで動く)
# README.md の「セットアップ」セクションにあるたまさんのサーバー ID を貼る
DISCORD_GUILD_ID=

# Gemini モデル (audio対応必須)
GEMINI_MODEL=gemini-2.5-flash

# 1チャンクの最大長 (秒)。長すぎるとレイテンシ↑、短すぎるとコスト↑
CHUNK_MAX_SECONDS=8.0

# 無音判定 (秒)。この時間音声が来なかったら発話終了とみなしてフラッシュ
SILENCE_TIMEOUT_SECONDS=0.8

# 日次コスト上限 (USD)。超えたら自動off
DAILY_BUDGET_USD=2.0

# ログレベル
LOG_LEVEL=INFO
